<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      `development` here means the app talks to APNs sandbox when run from
      Xcode (free dev signing or paid). Apple flips this to `production`
      automatically when you upload to TestFlight / App Store. Our edge
      function picks the right APNs host per `environment` field stored
      with each device token.
    -->
    <key>aps-environment</key>
    <string>development</string>
</dict>
</plist>
